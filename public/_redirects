# ─────────────────────────────────────────────────────────────────────
# Netlify redirects (order matters — first match wins).
# ─────────────────────────────────────────────────────────────────────

# Live sitemap.xml served by netlify/functions/sitemap.js
/sitemap.xml    /.netlify/functions/sitemap    200

# SPA fallback — every other path is served index.html so React Router
# can take over client-side. Must be LAST.
/*              /index.html                    200
